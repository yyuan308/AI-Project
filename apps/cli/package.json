{
  "name": "@aigrading/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "aigrading-benchmark": "dist/run-benchmark.js"
  },
  "scripts": {
    "benchmark": "tsx src/run-benchmark.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -b ../../packages/schemas ../../packages/grading ../../packages/evaluation ../../packages/report tsconfig.json --pretty false"
  },
  "dependencies": {
    "@aigrading/evaluation": "workspace:*",
    "@aigrading/grading": "workspace:*",
    "@aigrading/report": "workspace:*",
    "@aigrading/schemas": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
